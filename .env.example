# =============================================
# Open-Task — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================

# PostgreSQL
POSTGRES_USER=opentask
POSTGRES_PASSWORD=opentask_secret
POSTGRES_DB=opentask

# JWT — générez des secrets forts avec : openssl rand -hex 64
JWT_SECRET=changeme_jwt_secret_very_long_and_random
JWT_REFRESH_SECRET=changeme_refresh_secret_very_long_and_random

# Cookie refresh (local Docker HTTP : laisser false ; production HTTPS : true)
COOKIE_SECURE=false

# URLs (en production, remplacez par vos domaines)
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
WS_BASE_URL=http://localhost:4000
