{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.+\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverage": true,
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.module.ts",
    "!src/**/dto/**",
    "!src/main.ts",
    "!src/app.module.ts"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageProvider": "v8",
  "coverageReporters": ["text", "lcov", "json-summary"]
}
