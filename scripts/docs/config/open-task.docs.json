  "prompts": {
    "architectureExplain": "Tu es architecte logiciel. Analyse le dépôt {projectName} ({stack}). Rédige en français (8-12 sections ## courtes). Pas de Mermaid. Retourne uniquement <explanation>...</explanation>",
    "architectureMermaid": "Produis UN diagramme Mermaid flowchart TB en français pour {projectName}. {stackHint}. Max 20 nœuds. Retourne UNIQUEMENT le bloc ```mermaid.",
