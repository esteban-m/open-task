{
  "name": "open-task-docs-site",
  "private": true,
  "description": "Site documentation VitePress pour GitHub Pages",
  "type": "module",
  "scripts": {
    "prebuild": "node ../scripts/docs/cli.mjs assemble",
    "predev": "node ../scripts/docs/cli.mjs assemble",
    "build": "vitepress build && rm -rf ../docs-site && cp -r .vitepress/dist ../docs-site",
    "dev": "vitepress dev",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "mermaid": "^11.6.0",
    "vitepress": "^1.6.3",
    "vitepress-mermaid-viewer": "^0.4.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  }
}
